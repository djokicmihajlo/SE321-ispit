{
  "name": "auto-parts-shop",
  "private": true,
  "type": "module",
  "scripts": {
    "backend": "cd backend && ./mvnw spring-boot:run -Dspring-boot.run.profiles=local-mysql",
    "frontend": "cd frontend && npm run dev -- --host 127.0.0.1 --port 5173",
    "test:backend": "cd backend && ./mvnw test",
    "test:frontend": "cd frontend && npm run test",
    "build": "cd frontend && npm run build",
    "check": "npm run test:frontend && npm run build",
    "test:e2e": "cd e2e && npx playwright test",
    "test:regression": "npm run test:backend && npm run test:frontend && npm run build && npm run test:e2e"
  }
}
